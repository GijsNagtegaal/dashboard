<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            color: #e0e0e0;
            min-height: 100vh;
            padding: 2rem;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .header {
            margin-bottom: 3rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcf7f);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .last-updated {
            font-size: 0.875rem;
            color: #888;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1.5rem;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #aaa;
        }

        .card-icon {
            font-size: 1.5rem;
        }

        .card-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #fff;
        }

        .card-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .card-value {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
            background: linear-gradient(135deg, #ff6b6b, #ffd93d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .card-label {
            font-size: 0.875rem;
            color: #999;
            margin-bottom: 1rem;
        }

        .card-info {
            font-size: 0.875rem;
            color: #aaa;
            line-height: 1.6;
        }

        .card-info-item {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .card-info-item:last-child {
            border-bottom: none;
        }

        /* Spotify Card */
        .card-spotify {
            grid-column: span 1;
        }

        .spotify-track {
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: #fff;
        }

        .spotify-artist {
            font-size: 0.875rem;
            color: #aaa;
            margin-bottom: 1rem;
        }

        .spotify-status {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: rgba(29, 185, 84, 0.2);
            border: 1px solid #1db954;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #1db954;
        }

        .spotify-status.paused {
            background: rgba(191, 90, 91, 0.2);
            border-color: #bf5a5b;
            color: #bf5a5b;
        }

        .spotify-image {
            width: 100%;
            height: 150px;
            border-radius: 8px;
            object-fit: cover;
            margin-top: 1rem;
        }

        .spotify-container {
    text-align: center;
}

.spotify-info {
    margin: 1rem 0;
}

.spotify-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}

.control-btn {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    transition: transform 0.2s ease, color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.control-btn:hover {
    color: #1db954;
    transform: scale(1.2);
}

.control-btn.play-pause {
    font-size: 2.5rem;
    background: #fff;
    color: #000;
    width: 50px;
    height: 50px;
    border-radius: 50%;
}

.control-btn.play-pause:hover {
    background: #1db954;
    color: #fff;
}

.progress-container {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    margin-top: 10px;
}

.progress-bar {
    height: 100%;
    background: #1db954;
    border-radius: 2px;
    transition: width 0.5s linear;
}

        /* Commerce Card */
        .card-commerce {
            grid-column: span 1;
        }

        .commerce-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .commerce-stat {
            background: rgba(255, 255, 255, 0.05);
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .commerce-stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #6bcf7f;
            margin-bottom: 0.25rem;
        }

        .commerce-stat-label {
            font-size: 0.75rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .commerce-stat:hover {
            background: rgba(255, 255, 255, 0.1);
            cursor: pointer;
            border-color: rgba(255, 255, 255, 0.15);
        }

        .marketplace-link {
            text-decoration: none;
            color: inherit;
            display: block;
            transition: all 0.3s ease;
        }

        .marketplace-link:hover {
            text-decoration: none;
        }

        .view-orders-btn {
            width: 100%;
            padding: 0.75rem;
            margin-top: 1rem;
            background: linear-gradient(135deg, #6bcf7f, #4db86b);
            color: #000;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }

        .view-orders-btn:hover {
            background: linear-gradient(135deg, #7dd98d, #5dc678);
            transform: translateY(-2px);
        }

        /* Weather Card */
        .card-weather {
            grid-column: span 1;
        }

        .weather-icon {
            width: 80px;
            height: 80px;
            margin: 0.5rem 0;
        }

        .weather-temp {
            font-size: 3rem;
            font-weight: 700;
            color: #ffd93d;
            line-height: 1;
        }

        .weather-feels {
            font-size: 0.875rem;
            color: #aaa;
            margin-bottom: 1rem;
        }

        .weather-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            font-size: 0.8rem;
        }

        .weather-detail {
            background: rgba(255, 255, 255, 0.05);
            padding: 0.5rem;
            border-radius: 6px;
        }

        /* GitHub Card */
        .card-github {
            grid-column: span 1;
        }

        .github-stats {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .github-stat {
            text-align: center;
            background: rgba(255, 255, 255, 0.05);
            padding: 0.75rem;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .github-stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #ff6b6b;
        }

        .github-stat-label {
            font-size: 0.7rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Home Assistant Card */
        .card-ha {
            grid-column: span 1;
        }

        .ha-toggle-btn {
            padding: 0.75rem 1.5rem;
            background: linear-gradient(135deg, #6bcf7f, #4db86b);
            color: #000;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: auto;
            width: 100%;
        }

        .ha-toggle-btn:hover {
            background: linear-gradient(135deg, #7dd98d, #5dc678);
            transform: translateY(-2px);
        }

        .ha-toggle-btn:active {
            transform: translateY(0);
        }

        .ha-status {
            font-size: 1rem;
            font-weight: 600;
            padding: 0.5rem 1rem;
            background: rgba(107, 207, 127, 0.2);
            border: 1px solid #6bcf7f;
            border-radius: 6px;
            text-align: center;
            color: #6bcf7f;
            margin-bottom: 1rem;
        }

        .ha-status.off {
            background: rgba(191, 90, 91, 0.2);
            border-color: #bf5a5b;
            color: #bf5a5b;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .dashboard-grid {
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            }
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.75rem;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .card {
                padding: 1rem;
            }

            .card-value {
                font-size: 2rem;
            }
        }

        /* Error State */
        .card-error {
            color: #ff6b6b;
            font-size: 0.875rem;
        }

        /* Loading State */
        .loading {
            opacity: 0.6;
        }

        .loading::after {
            content: '';
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            margin-left: 0.5rem;
            vertical-align: middle;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Footer */
        .footer {
            text-align: center;
            color: #666;
            font-size: 0.875rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 Dashboard</h1>
            <div class="last-updated">
                Last updated: {{ now | date: "%Y-%m-%d %H:%M:%S" }}
            </div>
        </div>

        <div class="dashboard-grid">
            <!-- Spotify Card -->
            {% if spotify %}
                <div class="card card-spotify">
    <div class="card-header">
        <span class="card-icon">🎵</span>
        <span>Spotify</span>
    </div>
    <div class="card-content">
        {% if spotify.track %}
            <div class="spotify-container">
                {% if spotify.image %}
                    <img src="{{ spotify.image }}" alt="{{ spotify.track }}" class="spotify-image">
                {% endif %}
                
                <div class="spotify-info">
                    <div class="spotify-track">{{ spotify.track }}</div>
                    <div class="spotify-artist">{{ spotify.artist }}</div>
                </div>

                <!-- Controls Section -->
                <div class="spotify-controls">
                    <button onclick="spotifyAction('previous')" class="control-btn">⏮</button>
                    
                    {% if spotify.isPlaying %}
                        <button onclick="spotifyAction('pause')" class="control-btn play-pause">⏸</button>
                    {% else %}
                        <button onclick="spotifyAction('play')" class="control-btn play-pause">▶</button>
                    {% endif %}
                    
                    <button onclick="spotifyAction('next')" class="control-btn">⏭</button>
                </div>

                <!-- Progress Bar -->
                <div class="progress-container">
                    <div class="progress-bar" style="width: {{ spotify.progress | divided_by: spotify.duration | times: 100 }}%"></div>
                </div>
            </div>
        {% else %}
            <div class="card-info">No track currently playing</div>
        {% endif %}
    </div>
</div>
            {% endif %}

            <!-- Commerce Card (Shopify + Mirakl Combined) -->
            {% if commerce %}
                <div class="card card-commerce">
                    <div class="card-header">
                        <span class="card-icon">🛍️</span>
                        <span>Command Center</span>
                    </div>
                    <div class="card-content">
                        <div>
                            <div class="card-title">€ {{ commerce.totalValue | floor: 2 }}</div>
                            <div class="card-label">Combined Revenue</div>
                        </div>

                        <div class="commerce-grid">
                            <div class="commerce-stat">
                                <div class="commerce-stat-value">{{ commerce.totalOrders }}</div>
                                <div class="commerce-stat-label">Total Orders</div>
                            </div>
                            <div class="commerce-stat">
                                <div class="commerce-stat-value">2</div>
                                <div class="commerce-stat-label">Platforms</div>
                            </div>
                        </div>

                        <div class="card-info">
                            <div class="card-info-item">
                                <span>Shopify:</span>
                                <strong>{{ commerce.shopify.orderCount }} orders</strong>
                            </div>
                            <div class="card-info-item">
                                <span>Mirakl:</span>
                                <strong>{{ commerce.mirakl.orderCount }} orders</strong>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Weather Card -->
{% if weather %}
<div class="card card-weather">
    <div class="card-header">
        <span class="card-icon">🌤️</span>
        <span>Weather Forecast</span>
    </div>
    
    <div class="card-content">
        <!-- Main Current Display -->
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="weather-temp">{{ weather.temp }}°C</div>
                <div class="weather-feels">Feels like {{ weather.feelsLike }}°</div>
                <div style="color: #ffd93d; font-size: 0.9rem; text-transform: capitalize;">{{ weather.description }}</div>
            </div>
            <img src="{{ weather.icon }}" class="weather-icon" style="width: 100px; height: 100px; margin: 0;">
        </div>

        <!-- 6-Pack Stats Grid -->
        <div class="weather-details-grid">
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">WIND</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.wind }}</div>
            </div>
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">HUMIDITY</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.humidity }}</div>
            </div>
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">RANGE</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.range }}</div>
            </div>
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">VISIBILITY</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.visibility }}</div>
            </div>
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">PRESSURE</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.pressure }}</div>
            </div>
            <div class="weather-sub-card">
                <span style="font-size: 0.7rem; color: #888;">CLOUDS</span>
                <div style="font-size: 0.9rem; font-weight: 600;">{{ weather.stats.clouds }}</div>
            </div>
        </div>

        <!-- Hourly Scroll -->
        <div style="margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;">
            <span style="font-size: 0.8rem; color: #aaa;">24-Hour Forecast</span>
            <div class="hourly-container">
                {% for hour in weather.hourly %}
                <div class="hour-tick">
                    <div style="font-size: 0.65rem; color: #888;">{{ hour.time }}</div>
                    <img src="{{ hour.icon }}" style="width: 30px; height: 30px;">
                    <div style="font-size: 0.9rem; font-weight: 700;">{{ hour.temp }}°</div>
                    <div style="font-size: 0.6rem; color: #6bcf7f;">{{ hour.pop }}%</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endif %}

            <!-- GitHub Card -->
            {% if github %}
                <div class="card card-github">
                    <div class="card-header">
                        <span class="card-icon">🐙</span>
                        <span>GitHub</span>
                    </div>
                    <div class="card-content">
                        <div class="github-stats">
                            <div class="github-stat">
                                <div class="github-stat-value">{{ github.repoCount }}</div>
                                <div class="github-stat-label">Repos</div>
                            </div>
                            <div class="github-stat">
                                <div class="github-stat-value">{{ github.totalIssues }}</div>
                                <div class="github-stat-label">Issues</div>
                            </div>
                            <div class="github-stat">
                                <div class="github-stat-value">{{ github.totalPRs }}</div>
                                <div class="github-stat-label">Pull Requests</div>
                            </div>
                        </div>

                        <div class="card-info">
                            <strong>Recent Activity:</strong>
                            {% for repo in github.recentRepos %}
                                <div class="card-info-item" style="border: none;">
                                    <span>{{ repo.name }}</span>
                                    <span>⭐ {{ repo.stars }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}

<div class="printer-card">
    <h3>Bambu Lab P1S/X1C</h3>
    <div class="status">Status: <strong>{{ bambu.state }}</strong></div>
    
    {% if bambu.status == 'online' %}
        <div class="progress-container" style="background: #eee; height: 10px; border-radius: 5px;">
            <div class="progress-bar" style="width: {{ bambu.percent }}%; background: #007bff; height: 100%;"></div>
        </div>
        <p>{{ bambu.percent }}% Complete</p>
        <p>Nozzle: {{ bambu.temp_nozzle }}°C | Bed: {{ bambu.temp_bed }}°C</p>
    {% else %}
        <p class="offline-text">Printer is currently offline.</p>
    {% endif %}
</div>
        </div>

        <div class="footer">
            <p>🚀 Personal Dashboard • Powered by Node.js + Express + Liquid</p>
        </div>
    </div>
    <script>
async function spotifyAction(action) {
    try {
        // We assume your backend has a route like POST /api/spotify/control
        const response = await fetch(`/api/spotify/control?action=${action}`, {
            method: 'POST'
        });
        
        if (response.ok) {
            // Refresh the page or update UI manually to show state change
            setTimeout(() => window.location.reload(), 500);
        }
    } catch (err) {
        console.error("Failed to execute Spotify action", err);
    }
}
</script>
</body>
</html>
